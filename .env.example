# Copy to .env.local and fill in your cPanel email SMTP settings.
# cPanel → Email Accounts → Connect Devices → Secure SSL/TLS Settings

SMTP_HOST=mail.bsekompani.mk
SMTP_PORT=465
SMTP_USER=contact@bsekompani.mk
SMTP_PASS=your_email_account_password_here

# Where order/contact notifications are delivered
ORDER_EMAIL=contact@bsekompani.mk
CONTACT_EMAIL=contact@bsekompani.mk

# Optional: extra inbox(es) for order/contact notifications (comma-separated)
# NOTIFICATION_EMAIL_CC=other@example.com,second@example.com

# Set to false when cPanel mail uses a self-signed certificate (common)
SMTP_TLS_REJECT_UNAUTHORIZED=false
